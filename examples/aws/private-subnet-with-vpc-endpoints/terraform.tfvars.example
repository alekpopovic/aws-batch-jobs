aws_region          = "eu-central-1"
name                = "multicloud-scheduled-jobs-aws-private"
vpc_id              = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids          = ["subnet-privateaaaaaaaaa", "subnet-privatebbbbbbbbb"]
route_table_ids     = ["rtb-aaaaaaaaaaaaaaaaa", "rtb-bbbbbbbbbbbbbbbbb"]
container_image     = "<aws-account-id>.dkr.ecr.eu-central-1.amazonaws.com/my-batch-job:latest"
schedule_expression = "cron(0 3 * * ? *)"
schedule_timezone   = "Europe/Belgrade"

tags = {
  Project = "multicloud-scheduled-jobs"
  Env     = "prod"
}
